FROM ubuntu:24.04@sha256:c4a8d5503dfb2a3eb8ab5f807da5bc69a85730fb49b5cfca2330194ebcc41c7b

ARG DEBIAN_FRONTEND=noninteractive
RUN apt-get update && apt-get install -y \
    tini curl wget dnsutils git jq unzip zip less vim gosu \
    ca-certificates gnupg lsb-release sudo build-essential \
    && rm -rf /var/lib/apt/lists/*

RUN if id ubuntu >/dev/null 2>&1; then userdel -r ubuntu; fi && \
    if getent group ubuntu >/dev/null 2>&1; then groupdel ubuntu; fi && \
    groupadd -g 1000 sandbox && \
    useradd -m -u 1000 -g sandbox -s /bin/bash sandbox && \
    echo "sandbox ALL=(ALL) NOPASSWD:ALL" >> /etc/sudoers.d/sandbox

COPY entrypoint.sh /usr/local/bin/entrypoint.sh
COPY git-wrapper.sh /usr/local/bin/git
COPY healthcheck-poller.sh /usr/local/bin/healthcheck-poller.sh
RUN chmod +x /usr/local/bin/entrypoint.sh /usr/local/bin/git /usr/local/bin/healthcheck-poller.sh

# validation_tools — pinned DevOps validation toolchain (FR62, NFR16). See header for version bump procedure.
RUN set -eux; \
    cd /tmp; \
    dpkgArch="$(dpkg --print-architecture)"; \
    case "${dpkgArch}" in \
        amd64|arm64) ;; \
        *) echo "unsupported architecture: ${dpkgArch}" >&2; exit 1 ;; \
    esac; \
    case "${dpkgArch}" in \
        amd64) kubeLinterArchive="kube-linter-linux.tar.gz"; trivyArch="64bit" ;; \
        arm64) kubeLinterArchive="kube-linter-linux_arm64.tar.gz"; trivyArch="ARM64" ;; \
    esac; \
    # kubectl: arch uses $(dpkg --print-architecture) => amd64|arm64
    curl -fsSL "https://dl.k8s.io/release/v1.35.4/bin/linux/${dpkgArch}/kubectl" -o /tmp/kubectl && \
    install -m 0755 /tmp/kubectl /usr/local/bin/kubectl && \
    # helm: arch uses $(dpkg --print-architecture) => amd64|arm64
    curl -fsSL "https://get.helm.sh/helm-v3.20.2-linux-${dpkgArch}.tar.gz" -o /tmp/helm.tar.gz && \
    tar -xzf /tmp/helm.tar.gz -C /tmp && \
    install -m 0755 "/tmp/linux-${dpkgArch}/helm" /usr/local/bin/helm && \
    # kustomize: arch uses $(dpkg --print-architecture) => amd64|arm64
    curl -fsSL "https://github.com/kubernetes-sigs/kustomize/releases/download/kustomize%2Fv5.8.1/kustomize_v5.8.1_linux_${dpkgArch}.tar.gz" -o /tmp/kustomize.tar.gz && \
    tar -xzf /tmp/kustomize.tar.gz -C /tmp kustomize && \
    install -m 0755 /tmp/kustomize /usr/local/bin/kustomize && \
    # yq: arch uses $(dpkg --print-architecture) => amd64|arm64
    curl -fsSL "https://github.com/mikefarah/yq/releases/download/v4.53.2/yq_linux_${dpkgArch}" -o /tmp/yq && \
    install -m 0755 /tmp/yq /usr/local/bin/yq && \
    # opentofu: arch uses $(dpkg --print-architecture) => amd64|arm64
    curl -fsSL "https://github.com/opentofu/opentofu/releases/download/v1.11.6/tofu_1.11.6_linux_${dpkgArch}.tar.gz" -o /tmp/tofu.tar.gz && \
    tar -xzf /tmp/tofu.tar.gz -C /tmp tofu && \
    install -m 0755 /tmp/tofu /usr/local/bin/tofu && \
    # tflint: arch uses $(dpkg --print-architecture) => amd64|arm64
    curl -fsSL "https://github.com/terraform-linters/tflint/releases/download/v0.62.0/tflint_linux_${dpkgArch}.zip" -o /tmp/tflint.zip && \
    unzip -q /tmp/tflint.zip -d /tmp && \
    install -m 0755 /tmp/tflint /usr/local/bin/tflint && \
    # kubeconform: arch uses $(dpkg --print-architecture) => amd64|arm64
    curl -fsSL "https://github.com/yannh/kubeconform/releases/download/v0.7.0/kubeconform-linux-${dpkgArch}.tar.gz" -o /tmp/kubeconform.tar.gz && \
    tar -xzf /tmp/kubeconform.tar.gz -C /tmp kubeconform && \
    install -m 0755 /tmp/kubeconform /usr/local/bin/kubeconform && \
    # kube-linter: arch uses custom dpkg mapping => linux.tar.gz|linux_arm64.tar.gz
    curl -fsSL "https://github.com/stackrox/kube-linter/releases/download/v0.8.3/${kubeLinterArchive}" -o /tmp/kube-linter.tar.gz && \
    tar -xzf /tmp/kube-linter.tar.gz -C /tmp kube-linter && \
    install -m 0755 /tmp/kube-linter /usr/local/bin/kube-linter && \
    # trivy: arch uses custom dpkg mapping => 64bit|ARM64
    curl -fsSL "https://github.com/aquasecurity/trivy/releases/download/v0.70.0/trivy_0.70.0_Linux-${trivyArch}.tar.gz" -o /tmp/trivy.tar.gz && \
    tar -xzf /tmp/trivy.tar.gz -C /tmp trivy && \
    install -m 0755 /tmp/trivy /usr/local/bin/trivy && \
    # flux: arch uses $(dpkg --print-architecture) => amd64|arm64
    curl -fsSL "https://github.com/fluxcd/flux2/releases/download/v2.8.5/flux_2.8.5_linux_${dpkgArch}.tar.gz" -o /tmp/flux.tar.gz && \
    tar -xzf /tmp/flux.tar.gz -C /tmp flux && \
    install -m 0755 /tmp/flux /usr/local/bin/flux && \
    # sops: arch uses $(dpkg --print-architecture) => amd64|arm64
    curl -fsSL "https://github.com/getsops/sops/releases/download/v3.12.2/sops-v3.12.2.linux.${dpkgArch}" -o /tmp/sops && \
    install -m 0755 /tmp/sops /usr/local/bin/sops && \
    mkdir -p /home/sandbox/.cache/trivy /home/sandbox/.cache/helm /home/sandbox/.kube /home/sandbox/.terraform.d /home/sandbox/.config/sops && \
    chown -R sandbox:sandbox /home/sandbox/.cache /home/sandbox/.kube /home/sandbox/.terraform.d /home/sandbox/.config && \
    rm -rf /tmp/*

# exploration_tools — pinned code exploration toolchain (FR63, NFR16). See header for version bump procedure.
RUN set -eux; \
    cd /tmp; \
    dpkgArch="$(dpkg --print-architecture)"; \
    case "${dpkgArch}" in \
        amd64) astGrepArch="x86_64" ;; \
        arm64) astGrepArch="aarch64" ;; \
        *) echo "unsupported architecture: ${dpkgArch}" >&2; exit 1 ;; \
    esac; \
    apt-get update && \
    apt-get install -y --no-install-recommends \
        ripgrep=14.1.0-1 \
        fd-find=9.0.0-1 \
        universal-ctags=5.9.20210829.0-1 && \
    rm -rf /var/lib/apt/lists/* && \
    # fd-find installs as /usr/bin/fdfind on Debian/Ubuntu to avoid collision with an older tool.
    # Symlink to /usr/local/bin/fd so the upstream-documented command name works (AC#10).
    ln -sf /usr/bin/fdfind /usr/local/bin/fd && \
    # ast-grep: arch uses uname -m-style tokens => x86_64|aarch64 (mapped from dpkg arch above)
    curl -fsSL "https://github.com/ast-grep/ast-grep/releases/download/0.42.1/app-${astGrepArch}-unknown-linux-gnu.zip" -o /tmp/ast-grep.zip && \
    unzip -q /tmp/ast-grep.zip -d /tmp/ast-grep && \
    install -m 0755 /tmp/ast-grep/ast-grep /usr/local/bin/ast-grep && \
    rm -rf /tmp/*
{{- if .SDKs.NodeJS}}

ARG NODE_VERSION={{.SDKs.NodeJS}}
RUN curl -fsSL https://deb.nodesource.com/setup_${NODE_VERSION}.x | bash - && \
    apt-get install -y nodejs && \
    rm -rf /var/lib/apt/lists/* && \
    mkdir -p /home/sandbox/.npm-global && \
    chown sandbox:sandbox /home/sandbox/.npm-global
ENV NPM_CONFIG_PREFIX=/home/sandbox/.npm-global
ENV PATH="/home/sandbox/.npm-global/bin:${PATH}"
{{- end}}
{{- if .SDKs.Go}}

ARG GO_VERSION={{.SDKs.Go}}
RUN curl -fsSL https://go.dev/dl/go${GO_VERSION}.linux-$(dpkg --print-architecture).tar.gz | tar -C /usr/local -xz
ENV PATH="/usr/local/go/bin:${PATH}"
{{- end}}
{{- if .SDKs.Python}}

ARG PYTHON_VERSION={{.SDKs.Python}}
RUN apt-get update && \
    apt-get install -y software-properties-common && \
    add-apt-repository -y ppa:deadsnakes/ppa && \
    apt-get update && \
    apt-get install -y python${PYTHON_VERSION} python${PYTHON_VERSION}-venv python${PYTHON_VERSION}-dev && \
    update-alternatives --install /usr/bin/python3 python3 /usr/bin/python${PYTHON_VERSION} 1 && \
    update-alternatives --install /usr/bin/python python /usr/bin/python${PYTHON_VERSION} 1 && \
    curl -fsSL https://bootstrap.pypa.io/get-pip.py | python${PYTHON_VERSION} - --break-system-packages && \
    rm -rf /var/lib/apt/lists/* && \
    rm -f /usr/lib/python${PYTHON_VERSION}/EXTERNALLY-MANAGED
{{- end}}
{{- if .Packages}}

RUN apt-get update && apt-get install -y \
{{- range $i, $pkg := .Packages}}
    {{$pkg}} \
{{- end}}
    && rm -rf /var/lib/apt/lists/*
{{- end}}

RUN apt-get update && \
    apt-get install -y uidmap slirp4netns iproute2 iptables && \
    curl -fsSL "https://download.opensuse.org/repositories/devel:kubic:libcontainers:unstable/xUbuntu_$(lsb_release -rs)/Release.key" | gpg --dearmor -o /etc/apt/keyrings/kubic.gpg && \
    echo "deb [signed-by=/etc/apt/keyrings/kubic.gpg] https://download.opensuse.org/repositories/devel:kubic:libcontainers:unstable/xUbuntu_$(lsb_release -rs)/ /" > /etc/apt/sources.list.d/kubic.list && \
    apt-get update && \
    apt-get install -y podman podman-docker aardvark-dns netavark && \
    rm -rf /var/lib/apt/lists/*

RUN mkdir -p /etc/containers && \
    printf '[storage]\ndriver = "vfs"\n' > /etc/containers/storage.conf && \
    printf '[engine]\nevents_logger = "file"\n\n[network]\nnetwork_backend = "netavark"\n' > /etc/containers/containers.conf

RUN COMPOSE_VERSION=v5.0.1 && \
    curl -fsSL "https://github.com/docker/compose/releases/download/${COMPOSE_VERSION}/docker-compose-linux-$(uname -m)" -o /usr/local/bin/docker-compose && \
    chmod +x /usr/local/bin/docker-compose && \
    mkdir -p /usr/local/lib/docker/cli-plugins && \
    ln -s /usr/local/bin/docker-compose /usr/local/lib/docker/cli-plugins/docker-compose
{{- range .InstalledAgents}}
{{- if eq . "claude"}}

USER sandbox
ENV HOME=/home/sandbox
RUN curl -fsSL https://claude.ai/install.sh | bash
ENV PATH="/home/sandbox/.local/bin:${PATH}"
USER root
{{- end}}
{{- if eq . "gemini"}}

RUN npm install -g @google/gemini-cli@0.38.1 && \
    chown -R sandbox:sandbox /home/sandbox/.npm-global
{{- end}}
{{- if eq . "codex"}}

RUN npm install -g @openai/codex@0.122.0 && \
    chown -R sandbox:sandbox /home/sandbox/.npm-global
{{- end}}
{{- end}}
{{- if .InstalledAgents}}

COPY agent-instructions.md.tmpl /tmp/agent-instructions.md
{{- range .InstalledAgents}}
{{- if eq . "claude"}}
RUN cp /tmp/agent-instructions.md /home/sandbox/CLAUDE.md && chown sandbox:sandbox /home/sandbox/CLAUDE.md
{{- end}}
{{- if eq . "gemini"}}
RUN cp /tmp/agent-instructions.md /home/sandbox/GEMINI.md && chown sandbox:sandbox /home/sandbox/GEMINI.md
{{- end}}
{{- if eq . "codex"}}
RUN mkdir -p /home/sandbox/.codex && cp /tmp/agent-instructions.md /home/sandbox/.codex/AGENTS.md && chown -R sandbox:sandbox /home/sandbox/.codex
ENV CODEX_HOME=/home/sandbox/.codex
{{- end}}
{{- end}}
RUN rm -f /tmp/agent-instructions.md
{{- end}}
{{- if .HasMCP "playwright"}}

ENV PLAYWRIGHT_BROWSERS_PATH=/opt/playwright-browsers
ENV PLAYWRIGHT_MCP_BROWSER=chromium
RUN npm install -g @playwright/mcp@0.0.70 && \
    npx playwright install --with-deps chromium webkit && \
    mkdir -p /opt/playwright-browsers && \
    chown -R sandbox:sandbox /opt/playwright-browsers
{{- end}}

RUN mkdir -p /etc/sandbox && echo '{{.MCPManifestJSON}}' > /etc/sandbox/mcp-servers.json

ENV TERM=xterm-256color
ENV COLORTERM=truecolor
ENV TESTCONTAINERS_RYUK_DISABLED=true
ENV TESTCONTAINERS_HOST_OVERRIDE=localhost
{{- range $k, $v := .Env}}
ENV {{$k}}="{{dqescape $v}}"
{{- end}}

ENTRYPOINT ["/usr/bin/tini", "--", "/usr/local/bin/entrypoint.sh"]
WORKDIR /workspace
